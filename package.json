{
  "name": "osu-collection-downloader",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "description": "Desktop app to download osu! beatmap collections from osu!Collector",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mzackk/osucollections_downloader.git"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "dev:vite": "vite",
    "build": "vite build",
    "electron": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "axios": "^1.9.0",
    "electron-store": "^10.1.0",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^9.1.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "vite": "^8.1.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.osu.collector.downloader",
    "productName": "osu! Collection Downloader",
    "publish": [
      {
        "provider": "github",
        "owner": "mzackk",
        "repo": "osucollections_downloader"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    }
  }
}
